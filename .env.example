# OpenAI-compatible model gateway API key.
# The default config points at the currently tested gateway. Override
# MODELS_BASE_URL and config/llm_routing.yaml to use another compatible provider.
MODELS_BASE_URL=
MODELS_API_KEY=

# Semantic Scholar Graph API. Optional for unit tests, recommended for live
# graph runs because anonymous public quota is frequently throttled.
SEMANTIC_SCHOLAR_API_KEY=

# Serper web search. Optional unless a live model chooses the web_search tool.
SERPER_API_KEY=

# Runtime PostgreSQL database.
LITWEAVE_DATABASE_URL=postgresql://litweave:litweave@localhost:5432/litweave

# Langfuse (https://langfuse.com or self-hosted)
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
